      "faq": [
        {
          "_id": "7155623955951255575",
          "answer": "برای انتخاب اتاق مدنظرتان میان واحدهای اقامتی مختلف هتل شهر تهران، گزینه‌های متعددی پیش‌رودارید. به‌طورکلی واحدهای اقامتی در این هتل به دو نوع اتاق و سوئیت تقسیم می‌شوند. اتاق‌ها در مقایسه با سوئیت‌ها قیمت پایین‌تری دارند، ولی تفاوت قیمت میان اتاق‌ها هم، به درجه‌بندی و ظرفیت آن‌ها بستگی دارد. اتاق‌های هتل شهر تهران ظرفیت یک الی چهار نفره داشته و بعضی‌ از اتاق‌ها قابلیت اضافه کردن یک یا دو تخت تاشو برای نفرات بیشتر دارند.\nرزرو هتل تهران را می توانید از سایت علی بابا انجام دهید",
          "question": "هزینه رزرو هتل شهر تهران چقدر است؟"
        },
        {
          "_id": "7155623955951255576",
          "answer": "وب‌سایت علی بابا، با تیم مجرب و متخصص خود، امکان رزرو آنلاین هتل شهر تهران و سایر هتل‌های داخلی و خارجی را برای شما به ‌وجود آورده ‌است. با استفاده از آژانس مسافرتی علی بابا، فقط با چند کلیک ساده می‌توانید هتل موردنظرتان را بررسی، انتخاب و رزرو کنید.",
          "question": "آیا امکان رزرو آنلاین هتل شهر تهران وجود دارد؟"
        },
        {
          "_id": "7155623955951255577",
          "answer": "معیارهای متعددی برای رتبه‌بندی هتل‌ها وجوددارد. هتل شهر تهران با بیش‌ از 20 سال سابقه در زمینه هتلداری، با داشتن معیارها و پارامترهای موردنیاز، میان هتل‌های سه ستاره پایتخت جای ‌گرفته ‌است.\nرزرو\nتور تهران و تور تهران کیش </a را می توانید از سایت علی بابا انجام دهید.",
          "question": "هتل شهر تهران چند ستاره است؟"
        },
        {
          "_id": "7155623955951255578",
          "answer": "هتل شهر را در ابتدای مسیر ورود به منطقه شرق تهران می‌بینید. این هتل با قرار گرفتن در مجاورت پارک ملی سرخه‌حصار و دوری از آلودگی و ترافیک مرکز شهر، موقیت مکانی خوبی دارد. فقط با چند دقیقه پیاده‌روی می‌توانید خود را به پارک ملی سرخه‌حصار برسانید. هتل شهر تهران در خیابان دماوند، نبش سه‌راه تهرانپارس، به میهمانان خوش‌آمد می‌گوید. قرار داشتن هتل در شرق پایتخت سبب عدم‌دسترسی به مراکز مهم دیگر شهر نیست و هتل شهر با اتصال به بزرگراه‌ها و ایستگاه اتوبوس، امکان رفت‌وآمد به نواحی مختلف پایتخت را میسر می‌کند.",
          "question": "هتل شهر در کدام منطقه تهران قرار دارد و موقعیت جغرافیایی آن کجاست؟"
        },
        {
          "_id": "7155623955951255579",
          "answer": "ساعت 14 را برای گرفتن کلید اتاق‌تان از پرسنل هتل شهر در نظر بگیرید.برای این‌که هنگام تخلیه اتاق و خروج از هتل هم هزینه اضافه به لیست هزینه‌های اسکان شما اضافه نشود، توصیه می‌کنیم راس ساعت 12 ظهر، اتاق را به مجموعه هتل بازگردانید. ",
          "question": "زمان‌های ورود و خروج هتل شهر تهران چگونه است؟"
        },
        {
          "_id": "7155623955951255580",
          "answer": "هتل شهر تهران امکانات گوناگونی را برای راحتی و آسایش مسافران تدارک دیده که ازجمله آن‌ها می‌توان به آژانس مسافرتی، خدمات تهیه بلیط، خدمات برای افراد دارای معلولیت جسمی، لاندری، مینی‌بار غیررایگان، اپراتور، پارکینگ رایگان، تاکسی سرویس و... اشاره کرد. این هتل برای رفع نیازهای منشی‌گری مسافران و امکان انجام کارهای اداری و اینترنتی در هتل، همراه اینترنت رایگان و نامحدود در لابی و اینترنت در اتاق، فوتوکپی، فکس و پرینتر را به فهرست تسهیلات خود اضافه کرده ‌است. ",
          "question": "امکانات هتل شهر تهران چیست؟"
        },
        {
          "_id": "7155623955951255581",
          "answer": "فرودگاه مهرآباد تهران که برای پروازهای داخلی در نظر گرفته شده در فاصله تقریبی 26 کیلومتر از هتل شهر بوده و برای رفتن به این فرودگاه کمتراز 40 دقیقه زمان لازم دارید.",
          "question": "فاصله نزدیک‌ترین فرودگاه به هتل شهر تهران چقدر است؟"
        },
        {
          "_id": "7155623955951255582",
          "answer": "هتل سه ستاره بلوط،\nهتل حجاب تهران و هتل سه ستاره پرشیا 2 تهران را به مسافرانی که قصد سفر با قطار را دارند، توصیه می‌کنیم.",
          "question": "کدام هتل‌ها مشابه هتل شهر تهران هستد؟"
        }
