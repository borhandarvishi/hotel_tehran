      "faq": [
        {
          "_id": "7155623956030947342",
          "answer": "گران‌ترین واحد اقامتی هتل مینا آپارتمان دو خوابه شش نفره است؛ با توجه به ظرفیت بالای این واحد بسیاری از افراد در سفرهای خانوادگی برای اقامت سراغ این واحد می‌روند. فرقی نمی‌کند در کدام روز هفته این آپارتمان را رزرو کنید؛ هزینه رزرو این سوئیت در آخرهفته‌ها و غیر از آن یکسان است. در این واحد یک تخت دو نفره و چهار تخت یک نفره همراه یک سرویس کف‌خواب برای اقامت نفر اضافه وجود دارد.\nرزرو هتل در تهران را می توانید از سایت علی بابا انجام دهید.",
          "question": "هزینه رزرو هتل مینا تهران چقدر است؟"
        },
        {
          "_id": "7155623956030947343",
          "answer": "اگر می‌خواهید به رزرو آنلاین هتل مینا بپردازید، سری به سایت علی بابا بزنید و نام هتل مینا تهران را جستجو کنید. در این بخش با اطلاعاتی مانند معرفی هتل، امکانات و خدمات ارائه شده، قیمت رزرو هتل، تصاویری از بخش‌های مختلف آن و نظرات کاربران مواجه می‌شوید. برای رزرو آنلاین هتل مینا تهران از علی بابا باید در این مجموعه حساب کاربری داشته باشید.",
          "question": "آیا امکان رزرو آنلاین هتل مینا تهران وجود دارد؟"
        },
        {
          "_id": "7155623956030947344",
          "answer": "هتل دو ستاره مینا از قدیمی‌ترین اقامتگاه‌های تهران است. شاید ظاهر ساختمان هتل قدیمی باشد؛ ولی با توجه به آخرین بازسازی آن در سال 92 می‌توانید از زیبایی و تمیزی فضای داخلی و اتاق‌های هتل مینا مطمئن باشید.\nرزرو\nتور تهران و تور تهران کیش </a را می توانید از سایت علی بابا انجام دهید.",
          "question": "هتل مینا تهران چند ستاره است؟"
        },
        {
          "_id": "7155623956030947345",
          "answer": "هتل مینا در خیابان مفتح تهران قرار دارد؛ برای اقامت در این هتل دو ستاره باید خودتان را به آدرس میدان هفت تیر، خیابان دکتر مفتح جنوبی، بعد از چهارراه سمیه، روبروی دانشگاه خوارزمی، پلاک 82 برسانید. با اقامت در هتل دو ستاره مینا هشت کیلومتر تا میدان آزادی، 2.5 کیلومتر تا میدان هفت تیر، سه کیلومتر تا خیابان انقلاب، شش کیلومتر تا بلوار شریعتی و 1.5 کیلومتر تا بهارستان فاصله دارید.",
          "question": "هتل مینا در کدام منطقه تهران قرار دارد و موقعیت جغرافیایی آن کجاست؟"
        },
        {
          "_id": "7155623956030947346",
          "answer": "برای تحویل گرفتن اتاق خود در هتل مینا تهران باید ساعت 14 در هتل حاضر باشید. در آخرین روز اقامت باید کلید اتاق را نهایتا تا ساعت 12 به پرسنل پذیرش تحویل دهید. ",
          "question": "زمان‌های ورود و خروج هتل مینا تهران چگونه است؟"
        },
        {
          "_id": "7155623956030947347",
          "answer": "هتل دو ستاره مینا به‌شکلی طراحی شده که افراد کم‌توان نیز امکان اقامت در آن را داشته باشند. صندوق امانات این هتل بهترین جا برای نگهداری از وسایل قیمتی در طول سفر است. هتل مینا هیچ پارکینگی برای نگهداری از ماشین مسافران درنظر نگرفته است. مسافران برای این منظور می‌توانند از پارکینگ‌های اطراف هتل کمک بگیرند. اگر با هواپیما یا قطار سفر به تهران را تجربه می‌کنید، تاکسی سرویس هتل گزینه مناسب و راحتی برای جابه‌جایی در پایتخت است.",
          "question": "امکانات هتل مینا تهران چیست؟"
        },
        {
          "_id": "7155623956030947348",
          "answer": "هرچند سفر با هواپیما به مقصد تهران سریع‌تر است؛ اما احساس راحتی سفر با قطار را ندارد. مسافرانی که هواپیمایشان در فرودگاه مهرآباد می‌نشیند، 11 کیلومتر تا هتل مینا فاصله دارند. درصورتی‌که هواپیمای مسافران در فرودگاه امام خمینی توقف داشته باشد، کافی است مسیری 50 کیلومتری را طی کنند تا به هتل برسند. ",
          "question": "فاصله نزدیک‌ترین فرودگاه به هتل مینا تهران چقدر است؟"
        },
        {
          "_id": "7155623956030947349",
          "answer": "هتل پرستو، هتل دو ستاره حافظ، هتل فردوسی تهران ، هتل آپارتمان دو ستاره پارس و هتل دو ستاره اورین در قلب تهران",
          "question": "کدام هتل‌ها مشابه هتل مینا تهران هستند؟"
        }
      ],
