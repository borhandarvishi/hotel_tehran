      "faq": [
        {
          "_id": "7155623956240662529",
          "answer": "هتل ایریانو یکی از هتل‌های سه‌ستاره شهر تهران است. این هتل یکی از مناسب‌ترین هتل‌های اقتصادی شهر تهران به حساب می‌آید.",
          "question": "هتل ایریانو تهران چند ستاره است؟"
        },
        {
          "_id": "7155623956240662530",
          "answer": "هتل ایریانو در خیابان ولیعصر، خیابان لارستان قرار دارد. بعد از اینکه به خیابان مجلسی (ایرنا) رسیدید، جلوی پلاک 21 توقف کنید. بله شما درست روبه‌روی هتل قرار دارید.",
          "question": "موقعیت جغرافیایی هتل ایریانو تهران کجاست؟"
        },
        {
          "_id": "7155623956240662531",
          "answer": "فاصله هتل ایریانو تهران به مترو میدان جهاد بسیار نزدیک است. شما با پنج دقیقه پیاده‌روی به مترو خواهید رسید و از آنجا به هر مقصدی که در نظر داشته باشید دسترسی دارید. این هتل به دلیل موقعیت مکانی خوب، به مراکز مهم و پرتردد پایتخت نزدیک است؛ به‌عنوان مثال پارک لاله، میدان ولیعصر و پارک ساعی.",
          "question": "فاصله هتل ایریانو تهران تا مراکز مهم پایتخت چقدر است؟"
        },
        {
          "_id": "7155623956240662532",
          "answer": "زمان ورود به هتل ایریانو تهران، ساعت 14 است. زمان خروج هم مانند باقی هتل‌ها ساعت 12 است.",
          "question": "زمان‌های ورود و خروج هتل ایریانو تهران چگونه است؟"
        },
        {
          "_id": "7155623956240662533",
          "answer": "مبلغ رزرو هتل ایریانو تا سه روز قبل از زمان اقامت قابل‌استرداد است. درصد جریمه این مبلغ، با توجه به روزی که اقدام به کنسلی بلیط کرده‌اید،  متفاوت خواهد بود. می‌توانید قبل از رزرو اتاق مدنظرتان، از قسمت «قوانین کنسلی» میزان جریمه دقیقی که از کل مبلغ رزروتان کم می‌شود را ببینید. ",
          "question": "قوانین کنسلی هتل ایریانو تهران چگونه است؟"
        },
        {
          "_id": "7155623956240662534",
          "answer": "بخشی از امکانات هتل ایریانو به شرح زیر است:\nرستوران، کافی‌شاپ، خدمات خشکشویی، آلاچیق، تاکسی سرویس و خدمات اینترنت بی‌سیم.",
          "question": "امکانات هتل ایریانو تهران چیست؟"
        },
        {
          "_id": "7155623956240662535",
          "answer": "هتل شیراز، هتل مارلیک تهران و هتل آماتیس مشابه هتل ایریانو هستند؛ البته ممکن است هر کدام از این هتل‌ها در امکانات و ویژگی‌های خاصی نسبت به دیگری برتری داشته باشند. بهترین کار این است که همه این هتل‌ها را کنار هم بگذارید، با هم مقایسه کنید و در نهایت به یک تصمیم نهایی برسید.",
          "question": "کدام هتل‌ها مشابه هتل ایریانو تهران هستند؟"
        },
        {
          "_id": "7155623956240662536",
          "answer": "سرعت و سادگی فرایند رزرو هتل ایریانو تهران با علی‌بابا به کوتاهی چند کلیک ساده است. جدا از این می‌توانید به‌صورت 24ساعته از خدمات پشتیبانی علی‌بابا برای برطرف‌کردن تمام سوالات و درخواست‌هایتان کمک بگیرید.",
          "question": "چرا هتل ایریانو تهران را از علی‌بابا رزرو کنیم؟"
        }
      ],
