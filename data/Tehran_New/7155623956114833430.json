          }
        }
      ],
      "faq": [
        {
          "_id": "7155623956114833431",
          "answer": "هتل سه‌ستاره البرز تهران یکی از هتل‌های محبوب پایتخت است و در مرکز این شهر واقع شده است. این هتل به مراکز خرید و وسایل حمل‌و‌نقل عمومی دسترسی مناسبی دارد.",
          "question": "هتل البرز تهران چند ستاره است؟"
        },
        {
          "_id": "7155623956114833432",
          "answer": "اگر آدرس دقیق هتل البرز تهران را بخواهید، باید آن را در خیابان انقلاب، وصال شیرازی، درست نبش چهارراه بزرگمهر جستجو کنید.",
          "question": "موقعیت جغرافیایی هتل البرز تهران کجاست؟"
        },
        {
          "_id": "7155623956114833433",
          "answer": "همانطور که گفتیم هتل البرز تهران در مرکز شهر واقع شده و نزدیکی آن به مترو انقلاب و اتوبوس‌های تندرو، باعث می‌شود تا بتوانید خودتان را به‌راحتی و با هزینه‌ای کم، به هر نقطه‌ای از شهر برسانید.",
          "question": "فاصله هتل البرز تهران تا مراکز مهم پایتخت چقدر است؟"
        },
        {
          "_id": "7155623956114833434",
          "answer": "مثل بقیه هتل‌ها، ساعت ورود به هتل البرز تهران ساعت 14 و ساعت خروج از هتل و تحویل اتاق ساعت 12 ظهر است.",
          "question": "زمان‌های ورود و خروج در هتل البرز تهران چگونه است؟"
        },
        {
          "_id": "7155623956114833435",
          "answer": "مبلغ رزرو هتل البرز تهران غیرقابل‌استرداد است؛ این یعنی جریمه کنسلی رزرو این هتل صددرصدی است و بعد از کنسلی، هیچ مبلغی به شما برنمی‌گردد.",
          "question": "قوانین کنسلی هتل البرز تهران چگونه است؟"
        },
        {
          "_id": "7155623956114833436",
          "answer": "رستوران، کافی‌شاپ، خدمات خشکشویی، یخچال، تلویزیون، تاکسی سرویس و اینترنت بی‌سیم در قسمت پذیرش تنها چند نمونه از امکانات هتل البرز تهران هستند.",
          "question": "هتل البرز تهران چه امکاناتی دارد؟"
        },
        {
          "_id": "7155623956114833437",
          "answer": "هتل پامچال تهران، هتل بوتیک نظامیه و هتل ایریانو هتل‌های مشابه هتل البرز تهران هستند. شما می‌توانید با مقایسه این هتل‌ها و درنظرگرفتن فاکتورهایی مانند قیمت، منطقه و... به انتخاب نهایی‌تان برسید.",
          "question": "کدام هتل‌ها مشابه هتل البرز تهران هستند؟"
        },
        {
          "_id": "7155623956114833438",
          "answer": "رزرو هتل البرز تهران از علی‌بابا یعنی تجربه رزرو شیرین و آسان رزرو و اقامت؛ یعنی خدمات پشتیبانی رایگان و 24ساعته علی‌بابا که خیالتان را از تمام مراحل سفر راحت می‌کند.",
          "question": "چرا هتل البرز تهران را از علی‌بابا رزرو کنیم؟"
        }
      ],
