      "faq": [
        {
          "_id": "7155623956135804943",
          "answer": "قیمت اتاق‌های این هتل نسبت به ظرفیتی که دارند، کاملا متفاوت است و اینکه دو یا چند تخته باشند، آن‌ها را ارزان‌تر یا گران‌تر می‌کند.\nهتل های تهران را می توانید از سایت علی بابا رزرو کنید.",
          "question": "هزینه رزرو هتل آورین تهران چقدر است؟"
        },
        {
          "_id": "7155623956135804944",
          "answer": "خوشبختانه راه‌های مختلفی برای رزرو آنلاین هتل آورین تهران وجود دارد. در این ‌میان بهترین روش استفاده از سایت یا اپلیکیشن علی بابا است.",
          "question": "آیا امکان رزرو آنلاین هتل آورین تهران وجود دارد؟"
        },
        {
          "_id": "7155623956135804945",
          "answer": "هتل دو ستاره آورین در قلب تهران قرار گرفته است؛ به‌این‌ترتیب بسیاری از مسافران آن را برای اقامت انتخاب می‌کنند تا ضمن پرداخت هزینه کم‌تر به مراکز مهم پایتخت دسترسی داشته باشند.\nرزرو\nتور تهران و تور تهران کیش </a را می توانید از سایت علی بابا انجام دهید.",
          "question": "هتل آورین تهران چند ستاره است؟"
        },
        {
          "_id": "7155623956135804946",
          "answer": "برای رسیدن به هتل دو ستاره آورین باید سری به میدان انقلاب، ابتدای کارگر شمالی، کوچه مجد بزنید. این هتل دو ستاره در بورس کتاب‌فروشی و کافی‌شاپ تهران قرار دارد؛ ازاین‌رو برای علاقه‌مندان به هنر محل مناسبی برای اقامت است. هتل آورین دسترسی خوبی به پارک لاله، موزه هنرهای معاصر و موزه فرش ایران دارد.",
          "question": "هتل آورین در کدام منطقه تهران قرار دارد و موقعیت جغرافیایی آن کجاست؟"
        },
        {
          "_id": "7155623956135804947",
          "answer": "بهتر است برنامه سفرتان را جوری تنظیم کنید که ساعت 14 در هتل آورین باشید.پرسنل واحد خدمات بین ساعات 12 تا 14 اتاق را برای اقامت مسافران بعدی آماده می‌کنند. ",
          "question": "زمان‌های ورود و خروج هتل آورین تهران چگونه است؟"
        },
        {
          "_id": "7155623956135804948",
          "answer": "پارکینگ هتل دو ستاره آورین ظرفیت پذیرش 10 خودرو را دارد؛ برای استفاده از پارکینگ نیازی به پرداخت هزینه اضافه نیست. با تاکسی سرویس هتل به‌شکل 24 ساعته می‌توانید در شهر بگردید و تهران‌گردی کنید. آسانسور و خدمات ویژه افراد دارای معلولیت جسمی نمونه‌هایی از مناسب‌سازی هتل برای اقامت افراد کم‌توان است. در هتل آورین امکاناتی مانند شبکه پخش فیلم، دستگاه‌های اداری (فکس، پرینتر و فتوکپی)، لابی، خدمات خانه‌داری، خدمات بیدارباش، نمازخانه، زنگ هشدار، دستگاه واکس کفش، اینترنت و روزنامه وجود دارد.",
          "question": "امکانات هتل آورین تهران چیست؟"
        },
        {
          "_id": "7155623956135804949",
          "answer": "اگر با سفر هوایی خود را به تهران می‌رسانید، هواپیمای شما در یکی از دو فرودگاه بین‌المللی امام خمینی و مهرآباد می‌نشیند. هتل دو ستاره آورین در فاصله 48 کیلومتری از فرودگاه بین‌المللی امام خمینی واقع شده است.",
          "question": "فاصله نزدیک‌ترین فرودگاه به هتل آورین تهران چقدر است؟"
        },
        {
          "_id": "7155623956135804950",
          "answer": "اگر می‌خواهید درعین پرداخت هزینه کم برای اقامت در تهران، به مراکز مهم فرهنگی و تاریخی این کلان‌شهر دسترسی داشته باشید، هتل دو ستاره شهریار را برای اقامت انتخاب کنید.\nهتل آپارتمان دو ستاره ونوس در آدرس سهروردی شمالی، چهارراه کیوان، خیابان میرزایی، زینالی شرقی، شماره 31 بهترین گزینه برای اقامت‌های طولانی مدت است.\nهتل دو ستاره نادر تهران یکی از قدیمی‌ترین هتل‌های پایتخت است.\nهتل دو ستاره مینا را در شش طبقه و 75 اتاق و سوئیت ساخته‌اند.",
          "question": "کدام هتل‌ها مشابه هتل آورین تهران هستند؟"
        }
      ],
