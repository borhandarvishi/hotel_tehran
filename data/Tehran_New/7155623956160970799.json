      "faq": [
        {
          "_id": "7155623956160970800",
          "answer": "هتل آراد تهران یکی از هتل‌های یک‌ستاره شهر تهران است. این هتل از بهترین گزینه‌های اقتصادی برای اقامت در پایتخت محسوب می‌شود.",
          "question": "هتل آراد تهران چند ستاره است؟"
        },
        {
          "_id": "7155623956160970801",
          "answer": "هتل آراد در ابتدای خیابان شهید مطهری، خیابان لارستان، خیابان جهان سوز، پلاک 26 واقع شده است.",
          "question": "موقعیت جغرافیایی هتل آراد تهران کجاست؟"
        },
        {
          "_id": "7155623956160970802",
          "answer": "فاصله هتل آراد تهران تا کلیسای «سنت سرکیس» به‌صورت پیاده هفده دقیقه است. اگر بخواهید با ماشین از این هتل تا پاک ساعی بروید تقریبا پنج دقیقه راه دارید.",
          "question": "فاصله هتل آراد تهران تا مراکز مهم پایتخت چقدر است؟"
        },
        {
          "_id": "7155623956160970803",
          "answer": "زمان ورود به هتل آراد مثل باقی هتل‌هاست؛ یعنی ساعت 14 زمان خروج و تحویل اتاق هم به رسم ساعت استاندارد هتل‌ها یعنی راس 12 است.",
          "question": "زمان‌های ورود و خروج هتل آراد تهران چگونه است؟"
        },
        {
          "_id": "7155623956160970804",
          "answer": "از آنجایی که مبلغ رزرو هتل آراد تهران غیرقابل‌استرداد است، در صورت کنسلی، هیچ مبلغی به شما برنمی‌گردد.",
          "question": "قوانین کنسلی هتل آراد تهران چگونه است؟"
        },
        {
          "_id": "7155623956160970805",
          "answer": "از امکانات شاخص هتل آراد تهران می‌توان به رستوران، کافی‌شاپ، خدمات خشک‌شویی، صندوق امانات و اینترنت بی‌سیم اشاره کرد.",
          "question": "امکانات هتل آراد تهران چیست؟"
        },
        {
          "_id": "7155623956160970806",
          "answer": "هتل آران، هتل گلستان تهران و هتل رازی، مشابه هتل آراد هستند. با این همه، هر کدام از این هتل‌ها ممکن است امکانات و ویژگی‌های خاصی داشته باشند که آن‌ها را نسبت به یکدیگر متمایز می‌کند. پیشنهاد می‌کنیم که همه این هتل‌ها را در وب‌سایت علی‌بابا با هم مقایسه کنید و به تصمیم نهایی برسید.",
          "question": "کدام هتل‌ها مشابه هتل آراد تهران هستند؟"
        },
        {
          "_id": "7155623956160970807",
          "answer": "فرایند رزرو هتل آراد تهران با علی‌بابا مسیری سریع و آسان است. شما می‌توانید با چند کلیک ساده رزرو این هتل را از راه دور انجام دهید و بلافاصله بعد از رسیدن به مقصد، اقامت شیرینی در قلب شهر تهران تجربه کنید.",
          "question": "چرا هتل آراد تهران را از علی‌بابا رزرو کنیم؟"
        }
      ],
