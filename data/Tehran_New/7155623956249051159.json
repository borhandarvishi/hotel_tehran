      "faq": [
        {
          "_id": "7155623956249051160",
          "answer": "هتل الماس زعفرانیه، یکی از هتل‌های سه‌ستاره شمال تهران است که در دهکده نشاط ولیعصر قرار دارد.",
          "question": "هتل الماس زعفرانیه تهران چند ستاره است؟"
        },
        {
          "_id": "7155623956249051161",
          "answer": "برای رسیدن به هتل الماس زعفرانیه تهران، ابتدا به خیابان ولیعصر بروید. بعد از خیابان شهید فلاحی (زعفرانیه) به خیابان فیروز کوه شرقی می‌رسید. این هتل در خیابان روشن یکم، مجموعه دهکده نشاط ولیعصر قرار گرفته است.",
          "question": "موقعیت جغرافیایی هتل الماس زعفرانیه تهران کجاست؟"
        },
        {
          "_id": "7155623956249051162",
          "answer": "فاصله هتل الماس زعفرانیه تهران با مترو تجریش حدود پنج دقیقه با ماشین (بدون ترافیک) است؛ بنابراین می‌توانید با کمک مترو تردد کنید و خودتان را به مکان‌های مختلف شهر برسانید.\nفاصله این هتل تا برج میلاد هم بدون ترافیک، با ماشین حدودا به 15 دقیقه می‌رسد.",
          "question": "فاصله هتل الماس زعفرانیه تهران تا مراکز مهم پایتخت چقدر است؟"
        },
        {
          "_id": "7155623956249051163",
          "answer": "زمان ورود به هتل الماس زعفرانیه مانند باقی هتل‌ها ساعت 2 بعدازظهر است. زمان خروج هم طبق ساعت استاندارد همه هتل‌ها راس ساعت 12 ظهر است.",
          "question": "زمان‌های ورود و خروج هتل الماس زعفرانیه تهران چگونه است؟"
        },
        {
          "_id": "7155623956249051164",
          "answer": "مبلغی که بابت رزرو اتاق در هتل الماس زعفرانیه تهران پرداخت می‌کنید غیرقابل استرداد است؛ بنابراین حتما از رزرو و تصمیمتان برای اقامت در این هتل مطمئن شوید و بعد اقدام کنید.",
          "question": "قوانین کنسلی هتل الماس زعفرانیه تهران چگونه است؟"
        },
        {
          "_id": "7155623956249051165",
          "answer": "امکانات هتل سه‌ستاره الماس زعفرانیه کم نیست! از امکانات پذیرایی مثل رستوران و کافی‌شاپ گرفته تا امکانات ورزشی مثل استخر سرپوشیده؛\nدر کنار این‌ها خدمات خشکشویی، بالکن، سرویس بهداشتی فرنگی و ایرانی، سیستم تهیه هوا و آلاچیق را هم اضافه کنید.",
          "question": "امکانات هتل الماس زعفرانیه تهران چیست؟"
        },
        {
          "_id": "7155623956249051166",
          "answer": "هتل پامچال، ایریانو و هتل آماتیس تهران از چند جنبه به هتل الماس زعفرانیه شباهت دارند. می‌توانید امکانات و ویژگی‌های این هتل‌ها را کنار یکدیگر بگذارید؛ آن‌ها را با هم مقایسه کنید و در نهایت به تصمیم نهایی برسید.",
          "question": "کدام هتل‌ها مشابه هتل الماس زعفرانیه تهران هستند؟"
        },
        {
          "_id": "7155623956249051167",
          "answer": "یکی از دلایل رزرو آنلاین هتل، آسانی فرایند رزرو است. علی‌بابا این فرایند را برای همسفرانش بیش از پیش آسان و سریع کرده است. رزرو هتل الماس زعفرانیه با علی‌بابا، یعنی با چند کلیک ساده، کلید اتاق در دست شماست!\nامکان مشاهده نظرات مسافران قبلی، عکس‌های واقعی هتل و پشتیبانی 24ساعته علی‌بابا هم دلایل دیگری است که باعث می‌شود علی‌بابا را به هر همسفر دیگری ترجیح بدهید.",
          "question": "چرا هتل الماس زعفرانیه تهران را از علی‌بابا رزرو کنیم؟"
        }
      ],
