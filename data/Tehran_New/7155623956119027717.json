      "faq": [
        {
          "_id": "7155623956119027718",
          "answer": "ظرفیت اتاق‌های هتل بلوط تهران دو و سه ‌نفره است. هزینه رزرو اتاق‌های مختلف با توجه به ظرفیت واحدها فرق می‌کند. شما می‌توانید اتاق‌های هتل بلوط را برای اقامت کوتاه‌مدت رزرو کنید. برای رزرو اتاق‌ها برای اقامت‌های کوتاه توجه به این نکته ضروری است که سرویس صبحانه در این نوع از اقامت وجود ندارد. درضمن، مدت زمان اسکان کوتاه‌مدت نباید بیشتر از 10 ساعت باشد. در غیر این‌ صورت باید قیمت رزرو معمولی را بپردازید.\nرزرو هتل در تهران را می توانید از سایت علی بابا انجام دهید.",
          "question": "هزینه رزرو هتل بلوط تهران چقدر است؟"
        },
        {
          "_id": "7155623956119027719",
          "answer": "فرایند رزرو آنلاین هتل بلوط تهران را به وب‌سایت علی بابا بسپارید تا فقط با چند کلیک، اتاق موردنظرتان را انتخاب و به‌صورت اینترنتی، هزینه را پرداخت کنید.",
          "question": "آیا امکان رزرو آنلاین هتل بلوط تهران وجود دارد؟"
        },
        {
          "_id": "7155623956119027720",
          "answer": "هتل بلوط تهران با گردآوردن همه پارامترهای لازم یک هتل سه ستاره، میان هتل‌های سه ستاره شهر تهران به‌ چشم‌ می‌خورد.\nتور تهران و تور تهران کیش را می توانید از سایت علی بابا رزرو کنید.",
          "question": "هتل بلوط تهران چند ستاره است؟"
        },
        {
          "_id": "7155623956119027721",
          "answer": "سالانه افراد زیادی برای شرکت در رویدادهای گوناگون به نمایشگاه بین‌المللی تهران می‌آیند. هتل بلوط با فاصله کمی که تا نمایشگاه دارد، انتخاب بسیار مناسبی برای اقامت به ‌نظر می‌رسد. هتل بلوط تهران را می‌توانید در منطقه ولنجک، خیابان یمن، بالاتر از چهارراه مقدس اردبیلی پیدا کنید. این ناحیه یکی ‌از نواحی خوش آب‌وهوای شمال شهر تهران محسوب‌ می‌شود و برای افرادی که از شلوغی و آلودگی هوای مرکز شهر دوری می‌کنند، گزینه بسیار خوبی خواهد بود.   ",
          "question": "هتل بلوط در کدام منطقه تهران قرار دارد و موقعیت جغرافیایی آن کجاست؟"
        },
        {
          "_id": "7155623956119027722",
          "answer": "هتل بلوط ساعت 14 اتاق‌تان را تحویل می‌دهد و برای بازگرداندن واحد خود به مجموعه هتل هم زمان تخلیه اتاق را طوری تنظیم کنید که راس ساعت 12 ظهر، کلید واحد را به هتل تحویل دهید. ",
          "question": "زمان‌های ورود و خروج هتل بلوط تهران چگونه است؟"
        },
        {
          "_id": "7155623956119027723",
          "answer": "مجموعه آبی هتل شامل استخر روباز، سونا و جکوزی است و استفاده از استخر برای آقایان مقیم هتل هزینه‌ای در بر ندارد. علاوه‌براین مجموعه تفریحی و ورزشی، برای انجام تمرینات ورزشی و ادامه دادن تمرینات روزانه خود در سفر می‌توانید از سالن بدن‌سازی هتل بلوط استفاده کنید. لازم به ذکر است که استفاده از وسایل بدن‌سازی برای آقایان رایگان است. درنهایت خدمات ماساژ، فهرست امکانات ورزشی و تفریحی هتل بلوط را تکمیل می‌کند.",
          "question": "امکانات هتل بلوط چیست؟"
        },
        {
          "_id": "7155623956119027724",
          "answer": "طی کردن مسیر حدودا 21کیلومتری تا فرودگاه مهرآباد به ‌طور میانگین تقریبا نیم ساعت به‌ طول‌ می‌انجامد. اما مسافرانی که پروازشان خارجی باشد، باید زمان بیشتری را برای رسیدن به فرودگاه بین‌المللی امام خمینی(ره) در نظر بگیرند. از هتل بلوط تهران حدود یک ساعت تا این فرودگاه فاصله است.  ",
          "question": "فاصله نزدیک‌ترین فرودگاه به هتل بلوط تهران چقدر است؟"
        },
        {
          "_id": "7155623956119027725",
          "answer": "هتل امیر تهران ، هتل باباطاهر، هتل سه ستاره رزیدانس رودکی و هتل سه ستاره پاریز در شش طبقه و 40 واحد اقامتی، از گردشگران استقبال می‌کند.",
          "question": "کدام هتل‌ها مشابه هتل بلوط تهران هستند؟"
        }
      ],
